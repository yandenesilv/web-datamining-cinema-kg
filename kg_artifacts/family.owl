<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xml:base="http://example.org/family.owl"
         xmlns="http://example.org/family.owl#"
         xmlns:swrl="http://www.w3.org/2003/11/swrl#">

<owl:Ontology rdf:about="http://example.org/family.owl"/>

<owl:ObjectProperty rdf:about="#hasParent">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#hasChild"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasChild">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
  <owl:inverseOf rdf:resource="#hasParent"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasBrother">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Male"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSibling">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasUncle">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Male"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasGrandparent">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasCousin">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
</owl:ObjectProperty>

<owl:ObjectProperty rdf:about="#hasSpouse">
  <rdfs:domain rdf:resource="#Person"/>
  <rdfs:range rdf:resource="#Person"/>
</owl:ObjectProperty>

<owl:Class rdf:about="#Person">
  <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
</owl:Class>

<owl:Class rdf:about="#Male">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:Class rdf:about="#Female">
  <rdfs:subClassOf rdf:resource="#Person"/>
</owl:Class>

<owl:NamedIndividual rdf:about="#Jean">
  <rdf:type rdf:resource="#Male"/>
  <hasSpouse rdf:resource="#Marie"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Marie">
  <rdf:type rdf:resource="#Female"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Pierre">
  <rdf:type rdf:resource="#Male"/>
  <hasParent rdf:resource="#Jean"/>
  <hasParent rdf:resource="#Marie"/>
  <hasBrother rdf:resource="#Paul"/>
  <hasSibling rdf:resource="#Paul"/>
  <hasSpouse rdf:resource="#Sophie"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Sophie">
  <rdf:type rdf:resource="#Female"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Paul">
  <rdf:type rdf:resource="#Male"/>
  <hasParent rdf:resource="#Jean"/>
  <hasParent rdf:resource="#Marie"/>
  <hasBrother rdf:resource="#Pierre"/>
  <hasSibling rdf:resource="#Pierre"/>
  <hasSpouse rdf:resource="#Claire"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Claire">
  <rdf:type rdf:resource="#Female"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Lucas">
  <rdf:type rdf:resource="#Male"/>
  <hasParent rdf:resource="#Pierre"/>
  <hasParent rdf:resource="#Sophie"/>
  <hasSibling rdf:resource="#Emma"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Emma">
  <rdf:type rdf:resource="#Female"/>
  <hasParent rdf:resource="#Pierre"/>
  <hasParent rdf:resource="#Sophie"/>
  <hasSibling rdf:resource="#Lucas"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="#Hugo">
  <rdf:type rdf:resource="#Male"/>
  <hasParent rdf:resource="#Paul"/>
  <hasParent rdf:resource="#Claire"/>
</owl:NamedIndividual>

<swrl:Variable rdf:about="urn:swrl#x"/>

<swrl:Variable rdf:about="urn:swrl#y"/>

<swrl:Variable rdf:about="urn:swrl#z"/>

<swrl:Variable rdf:about="urn:swrl#w"/>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasParent"/>
              <swrl:argument1 rdf:resource="urn:swrl#x"/>
              <swrl:argument2 rdf:resource="urn:swrl#y"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#hasSibling"/>
                  <swrl:argument1 rdf:resource="urn:swrl#y"/>
                  <swrl:argument2 rdf:resource="urn:swrl#z"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest>
                <rdf:Description>
                  <rdf:first>
                    <swrl:IndividualPropertyAtom>
                      <swrl:propertyPredicate rdf:resource="#hasChild"/>
                      <swrl:argument1 rdf:resource="urn:swrl#z"/>
                      <swrl:argument2 rdf:resource="urn:swrl#w"/>
                    </swrl:IndividualPropertyAtom>
                  </rdf:first>
                  <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
                </rdf:Description>
              </rdf:rest>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasCousin"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#w"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasParent"/>
              <swrl:argument1 rdf:resource="urn:swrl#x"/>
              <swrl:argument2 rdf:resource="urn:swrl#y"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#hasParent"/>
                  <swrl:argument1 rdf:resource="urn:swrl#y"/>
                  <swrl:argument2 rdf:resource="urn:swrl#z"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasGrandparent"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#z"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>

<swrl:Imp>
  <swrl:body>
    <rdf:Description>
      <rdf:first>
        <swrl:ClassAtom>
          <swrl:classPredicate rdf:resource="#Person"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
        </swrl:ClassAtom>
      </rdf:first>
      <rdf:rest>
        <rdf:Description>
          <rdf:first>
            <swrl:IndividualPropertyAtom>
              <swrl:propertyPredicate rdf:resource="#hasParent"/>
              <swrl:argument1 rdf:resource="urn:swrl#x"/>
              <swrl:argument2 rdf:resource="urn:swrl#y"/>
            </swrl:IndividualPropertyAtom>
          </rdf:first>
          <rdf:rest>
            <rdf:Description>
              <rdf:first>
                <swrl:IndividualPropertyAtom>
                  <swrl:propertyPredicate rdf:resource="#hasBrother"/>
                  <swrl:argument1 rdf:resource="urn:swrl#y"/>
                  <swrl:argument2 rdf:resource="urn:swrl#z"/>
                </swrl:IndividualPropertyAtom>
              </rdf:first>
              <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
            </rdf:Description>
          </rdf:rest>
        </rdf:Description>
      </rdf:rest>
    </rdf:Description>
  </swrl:body>
  <swrl:head>
    <rdf:Description>
      <rdf:first>
        <swrl:IndividualPropertyAtom>
          <swrl:propertyPredicate rdf:resource="#hasUncle"/>
          <swrl:argument1 rdf:resource="urn:swrl#x"/>
          <swrl:argument2 rdf:resource="urn:swrl#z"/>
        </swrl:IndividualPropertyAtom>
      </rdf:first>
      <rdf:rest rdf:resource="http://www.w3.org/1999/02/22-rdf-syntax-ns#nil"/>
    </rdf:Description>
  </swrl:head>
</swrl:Imp>


</rdf:RDF>
